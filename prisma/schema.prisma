generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  SUPERVISOR
  TECHNICIAN
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  BLOCKED
  CLOSED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum EvidenceType {
  COMMENT
  PHOTO
  FILE
  LOCATION
}

model User {
  id        String         @id @default(uuid())
  name      String
  email     String         @unique
  role      UserRole       @default(TECHNICIAN)
  tasks     Task[]
  evidences TaskEvidence[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model Client {
  id        String   @id @default(uuid())
  name      String   @unique
  branches  Branch[]
  tasks     Task[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Branch {
  id        String   @id @default(uuid())
  name      String
  address   String?
  city      String?
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id])
  tasks     Task[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
}

model Task {
  id           String       @id @default(uuid())
  title        String
  description  String?
  status       TaskStatus   @default(PENDING)
  priority     TaskPriority @default(MEDIUM)
  dueDate      DateTime
  closedAt     DateTime?

  clientId     String
  branchId     String
  assignedToId String

  client       Client       @relation(fields: [clientId], references: [id])
  branch       Branch       @relation(fields: [branchId], references: [id])
  assignedTo   User         @relation(fields: [assignedToId], references: [id])
  evidences    TaskEvidence[]

  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([status])
  @@index([priority])
  @@index([dueDate])
  @@index([clientId])
  @@index([branchId])
  @@index([assignedToId])
}

model TaskEvidence {
  id        String       @id @default(uuid())
  taskId    String
  userId    String
  type      EvidenceType
  comment   String?
  fileUrl   String?
  latitude  Float?
  longitude Float?

  task      Task         @relation(fields: [taskId], references: [id])
  user      User         @relation(fields: [userId], references: [id])

  createdAt DateTime     @default(now())

  @@index([taskId])
  @@index([userId])
}